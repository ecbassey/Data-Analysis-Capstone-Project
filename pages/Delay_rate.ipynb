fig, ax = plt.subplots(figsize=(12,8))
monthly_delays.sort_values(by='month').plot(
    kind='bar',
    ax=ax
)
ax.set_title("Airline Delay Rate")
ax.set_xlabel("Delay Rate")
st.pyplot(fig)


